<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net6.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>DesktopIconToggler</AssemblyName>
    <RootNamespace>DesktopIconToggler</RootNamespace>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <Version>1.0.0</Version>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <Product>Desktop Icon Toggler</Product>
    <Company>Animesh Hedaoo</Company>
    <Copyright>Copyright © 2025 Animesh Hedaoo</Copyright>
    <Description>System tray app to toggle desktop icon visibility on Windows 10/11</Description>
  </PropertyGroup>

</Project>
